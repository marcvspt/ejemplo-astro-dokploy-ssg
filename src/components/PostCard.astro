---
import type { BlogCardData } from "@/scripts/types";

interface Props {
    post: BlogCardData;
}

const { post } = Astro.props;
---

<article class="post-card">
    <img src={post.image} alt={post.title} loading="lazy" />
    <div class="post-card-content">
        <div class="post-meta">
            <span>{post.category}</span>
            <span>•</span>
            <time>
                {
                    post.date.toLocaleDateString("es-ES", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                    })
                }
            </time>
            <span>•</span>
            <span>{post.readTime}</span>
        </div>

        <h2>{post.title}</h2>
        <p>{post.excerpt}</p>

        <div class="tag-list">
            {post.tags.map((tag) => <span>{tag}</span>)}
        </div>

        <a href={`/${post.slug}`} class="read-link"> Leer publicación </a>
    </div>
</article>
