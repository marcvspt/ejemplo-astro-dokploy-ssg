---
import type { BlogPostData } from "@/scripts/types";

interface Props {
    frontmatter: BlogPostData;
}

const { frontmatter } = Astro.props;
const { title, excerpt, date, updated, readTime, category, tags, image } =
    frontmatter;

const formatDate = (dateObj: Date) => {
    return dateObj.toLocaleDateString("es-ES", {
        year: "numeric",
        month: "long",
        day: "numeric",
    });
};
---

<header class="post-header">
    <p class="eyebrow">{category}</p>
    <h1>{title}</h1>
    <p class="post-summary">{excerpt}</p>
    <p class="post-date-line">
        {formatDate(date)} • {readTime}
        {updated && <> • Actualizado: {formatDate(updated)}</>}
    </p>

    {
        tags.length > 0 && (
            <ul class="tag-list" aria-label="Etiquetas de la publicación">
                {tags.map((tag) => (
                    <li>
                        <span>{tag}</span>
                    </li>
                ))}
            </ul>
        )
    }
</header>

<img src={image} alt={`Imagen destacada para ${title}`} class="post-cover" />
